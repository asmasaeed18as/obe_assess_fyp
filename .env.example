# ============================================
# Django Application Environment Variables
# ============================================

# SECURITY WARNING: Generate a strong SECRET_KEY in production
# Run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-strong-secret-min-50-chars

# Debug mode: Set to False in production
# True = Detailed error pages (development only)
# False = Generic error pages (production)
DEBUG=False

# ============================================
# Database Configuration
# ============================================

# Option 1: Use DATABASE_URL (recommended for Render/cloud)
# Format: postgresql://user:password@hostname:port/database
DATABASE_URL=postgresql://obe_user:obe_password@db-hostname:5432/obe_db

# Option 2: Use individual DB fields (if DATABASE_URL not set)
# Database engine: django.db.backends.postgresql or django.db.backends.sqlite3
DB_ENGINE=django.db.backends.postgresql
DB_NAME=obe_db
DB_USER=obe_user
DB_PASSWORD=obe_password
DB_HOST=localhost
DB_PORT=5432

# ============================================
# LLM Service Configuration
# ============================================

# URL to the LLM microservice
# Local: http://localhost:8001
# Render: https://obe-assess-llm.onrender.com
LLM_SERVICE_URL=http://localhost:8001

# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=replace-with-your-groq-api-key

# Groq API base URL (usually unchanged)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Groq model to use (available models listed at console.groq.com)
# Options: llama-3.1-70b-versatile, mixtral-8x7b-32768, etc.
GROQ_MODEL=llama-3.1-70b-versatile

# ============================================
# Frontend Configuration (Vite)
# ============================================

# Backend API base URL
# Local: http://localhost:8000/api
# Render: https://obe-assess-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:8000/api
