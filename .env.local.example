# Development Environment Configuration
# Copy this to .env for local development
# DO NOT commit actual secrets to version control

# Django Configuration
SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True

# ============================================
# Database Configuration (Local Development)
# ============================================
# Option 1: SQLite (Default, no setup needed)
# Leave commented if using SQLite
# DB_ENGINE=django.db.backends.sqlite3

# Option 2: PostgreSQL (Install locally or Docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=obe_db_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# OR use DATABASE_URL format:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/obe_db_dev

# ============================================
# LLM Service Configuration
# ============================================
# Local LLM Service (running on localhost:8001)
LLM_SERVICE_URL=http://localhost:8001

# Groq API Configuration (get from console.groq.com)
GROQ_API_KEY=gsk_your_local_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-70b-versatile

# ============================================
# Frontend Configuration (Local Development)
# ============================================
VITE_API_BASE_URL=http://localhost:8000/api
