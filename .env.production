# ============================================
# OBE Assessment Platform - Production Environment
# Render Deployment Configuration
# ============================================

# Django Configuration
# IMPORTANT: Generate a strong SECRET_KEY in production
# Run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-strong-secret-key-here-min-50-chars

# Debug Mode - MUST be False in production
DEBUG=False

# ============================================
# Database Configuration
# Render PostgreSQL Connection
# ============================================
# Use PostgreSQL on Render (recommended for production)
DB_ENGINE=django.db.backends.postgresql
DATABASE_URL=postgresql://username:password@render-postgres-host:5432/database_name

# Alternative: If using environment variable directly (Render generates this)
# Leave DATABASE_URL empty and use individual DB fields:
# DB_NAME=obe_db
# DB_USER=postgres
# DB_PASSWORD=your_postgres_password
# DB_HOST=your-render-db-host
# DB_PORT=5432

# ============================================
# LLM Service Configuration
# Groq API for Assessment & Marking
# ============================================
# URL to your LLM service (internal service communication on Render)
LLM_SERVICE_URL=https://obe-assess-llm.onrender.com

# Groq API Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
# Frontend Configuration
# ============================================
VITE_API_BASE_URL=https://obe-assess-backend.onrender.com/api
